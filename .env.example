DATABASE_URL="postgresql://postgres:docker@localhost:5432/hms?schema=public"
AUTH_SECRET="your-secret-here"
# Absolute base URL used to build links in outbound email (e.g. password reset).
AUTH_URL="http://localhost:3000"
CRON_SECRET="your-cron-secret"
NODE_ENV="development"
VERSION="0.0.0"

# S3 — for local dev with MinIO (docker compose up minio)
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="hms-uploads"
S3_ENDPOINT="http://localhost:9000"

# SMTP — for local dev with Mailpit (docker compose up mailpit)
SMTP_HOST="localhost"
SMTP_PORT="1025"
